# AgentWorks — environment template
# Copy to .env and fill in. NEVER commit .env. NEVER paste real values into FACTS.md or docs.
# Variable names below are PROVISIONAL until confirmed in Phase 0 (see docs/FACTS.md).

# ── CAW (Cobo Agentic Wallet) ──────────────────────────────────────────
# Phase 0 VERIFIED (see docs/FACTS.md): the SDK examples read these three names.
AGENT_WALLET_API_URL=https://api.agenticwallet.cobo.com
AGENT_WALLET_API_KEY=
AGENT_WALLET_WALLET_ID=
# Onboarding-time only (CLI). Optional depending on onboarding flow.
CAW_INVITATION_CODE=
# Per-agent identifiers for our two-agent setup (fill once wallets exist in Phase 2).
# Each agent runs its own WalletAPIClient with its own wallet id + (pact-scoped) api key.
CAW_CLIENT_WALLET_ID=
CAW_CLIENT_API_KEY=
CAW_PROVIDER_WALLET_ID=
CAW_PROVIDER_API_KEY=

# ── Chain / RPC ────────────────────────────────────────────────────────
CHAIN=base-sepolia
RPC_URL=
# Deployer key for Foundry (testnet only — never a key with real funds)
DEPLOYER_PRIVATE_KEY=
# BaseScan API key for contract verification
EXPLORER_API_KEY=

# ── Contracts (fill after Phase 1 deploy) ──────────────────────────────
ESCROW_CONTRACT_ADDRESS=
USDC_TOKEN_ADDRESS=

# ── Irys (deliverable storage — Phase 5) ───────────────────────────────
IRYS_PRIVATE_KEY=
IRYS_NODE_URL=

# ── LLM (agent reasoning / evaluator) ──────────────────────────────────
# Used by the Client/Provider agents and the evaluator for genuine reasoning.
LLM_API_KEY=
LLM_MODEL=