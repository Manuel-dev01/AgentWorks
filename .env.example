# AgentWorks — environment template
# Copy to .env and fill in. NEVER commit .env. NEVER paste real values into FACTS.md or docs.
# Variable names below are PROVISIONAL until confirmed in Phase 0 (see docs/FACTS.md).

# ── CAW (Cobo Agentic Wallet) ──────────────────────────────────────────
# Confirm exact names against the real SDK/docs in Phase 0 before relying on these.
CAW_API_BASE=https://api.agenticwallet.cobo.com
CAW_INVITATION_CODE=
CAW_API_KEY=
# Per-agent identifiers (fill once wallets exist in Phase 2)
CAW_CLIENT_WALLET_ID=
CAW_PROVIDER_WALLET_ID=

# ── Chain / RPC ────────────────────────────────────────────────────────
CHAIN=base-sepolia
RPC_URL=
# Deployer key for Foundry (testnet only — never a key with real funds)
DEPLOYER_PRIVATE_KEY=
# BaseScan API key for contract verification
EXPLORER_API_KEY=

# ── Contracts (fill after Phase 1 deploy) ──────────────────────────────
ESCROW_CONTRACT_ADDRESS=
USDC_TOKEN_ADDRESS=

# ── Irys (deliverable storage — Phase 5) ───────────────────────────────
IRYS_PRIVATE_KEY=
IRYS_NODE_URL=

# ── LLM (agent reasoning / evaluator) ──────────────────────────────────
# Used by the Client/Provider agents and the evaluator for genuine reasoning.
LLM_API_KEY=
LLM_MODEL=