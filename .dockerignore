# Keep the build context small + never ship secrets.
**/.venv
**/node_modules
**/__pycache__
**/*.pyc
.git
# Ignore runtime-written marketplace data, but ship the committed seed (board + verified run artifacts)
# so /runs isn't empty on a fresh volume. The committed set is small + non-secret; live data goes on the
# mounted volume (AGENT_DATA_DIR), never the image.
**/.market
!agents/scripts/.market/board.json
!agents/scripts/.market/runs/*.json
**/.flow
web
contracts/lib
contracts/cache
contracts/broadcast
contracts/out
# (the v2 ABI is vendored at agents/abi/AgentWorksEscrowV2.json, so contracts/out isn't needed)
# Secrets — never in an image. Provide config via --env-file / platform env at run time.
.env
.env.*
!.env.example
**/registry.local.json
*.log
